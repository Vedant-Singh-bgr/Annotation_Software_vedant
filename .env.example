# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# The schema provider is "postgresql" (prisma/schema.prisma). Use a managed
# Postgres for both dev and prod — Neon (neon.tech) has a free tier and needs no
# local disk. Format:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Local Postgres via docker-compose.yml is also fine:
#   DATABASE_URL="postgresql://annotator:annotator@localhost:5432/annotation?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── App URL ──────────────────────────────────────────────────────────────────
# Public base URL of the deployed web app. The transcode worker calls this to
# claim jobs and report results. Locally: http://localhost:3000
APP_URL="http://localhost:3000"

# ── Auth ───────────────────────────────────────────────────────────────────
# 32+ char random string. Generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-please-change-me"

# ── Cloudflare R2 (S3-compatible) ──────────────────────────────────────────
# Leave blank to run in "demo" mode, where videos stream from Video.sourceUrl
# instead of R2. Fill these in to stream your real R2 objects by key.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Presigned URL lifetime in seconds (default 3600).
R2_URL_TTL="3600"

# ── MCAP → MP4 proxy transcode ─────────────────────────────────────────────
# Shared secret the background transcode uses to report its result back to
# POST /api/admin/clips/[id]/proxy (x-transcode-secret header). Required for the
# server-triggered "Run transcode" button; not needed for the manual paste path.
TRANSCODE_SECRET=""
# Python interpreter that has the transcode deps (mcap, imageio-ffmpeg, boto3).
# Defaults to "python" on PATH.
PYTHON_BIN="python"
